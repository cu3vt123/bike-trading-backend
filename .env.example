# ===========================================
# ShopBike Frontend – API & Environment
# Copy to .env and adjust for your setup
# ===========================================

# Backend API base URL (no trailing slash)
# Local demo backend: http://localhost:8081/api
# Production: https://your-api.example.com/api
VITE_API_BASE_URL=http://localhost:8081/api

# Request timeout in ms (optional, default 15000)
# VITE_API_TIMEOUT=15000

# Use mock data instead of real API
# true = mock (no backend needed), false = call real API
VITE_USE_MOCK_API=false
