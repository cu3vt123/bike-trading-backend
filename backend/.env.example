PORT=8081
MONGODB_URI=
JWT_SECRET=dev_secret_change_me
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Base URL công khai của backend (ảnh tin đăng: /uploads/listings/...). Nếu để trống, dùng Host của request.
PUBLIC_ORIGIN=http://localhost:8081

# --- VNPAY Sandbox (module /payment + checkout buyer + gói seller) ---
# Lấy TMN + HashSecret tại https://sandbox.vnpayment.vn/
# Return / IPN: URL public trỏ vào backend (vd ngrok → cổng PORT), không phải chỉ frontend.
VNP_TMNCODE=
VNP_HASHSECRET=
VNP_PAYURL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURNURL=
VNP_IPNURL=

# Bỏ qua màn chọn phương thức (QR, thẻ QT, app) — mặc định NCB. Đổi nếu muốn ngân hàng khác.
# VNP_BANKCODE=TCB

# Tương thích tên cũ (nếu đã có sẵn trong .env)
# VNP_TMN_CODE=  VNP_HASH_SECRET=  VNP_PAY_URL=  VNP_RETURNURL=  VNP_IPNURL=

# If MONGODB_URI is empty, server will use in-memory MongoDB for demo
